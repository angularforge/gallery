{
  "name": "@angularforge/gallery",
  "version": "2.0.0",
  "description": "A feature-rich, accessible Angular image gallery library with lightbox, full-gallery, and share support. Built with Angular signals and OnPush change detection.",
  "keywords": [
    "angular",
    "gallery",
    "image-gallery",
    "lightbox",
    "angularforge",
    "angular-library",
    "standalone",
    "signals"
  ],
  "author": {
    "name": "AngularForge",
    "email": "smerlynjaviereusebiobonifacio@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/angularforge/gallery"
  },
  "bugs": {
    "url": "https://github.com/angularforge/gallery/issues"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "typecheck": "ngc -p tsconfig.typecheck.json",
    "test": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:watch": "ng test",
    "pack:local": "npm run build && cd dist && npm pack"
  },
  "peerDependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0"
  },
  "dependencies": {
    "@ng-icons/bootstrap-icons": "^33.3.0",
    "@ng-icons/core": "^33.3.0",
    "@ng-icons/heroicons": "^33.3.0",
    "@ng-icons/lucide": "^33.3.0",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^22.0.0",
    "typescript": ">=5.5.0",
    "zone.js": "~0.15.0"
  },
  "sideEffects": false
}
